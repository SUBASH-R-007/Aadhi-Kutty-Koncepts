# --- Database (docker-compose.yml provides this locally: `docker compose up -d db`) ---
DATABASE_URL="postgresql://aadhi:aadhi@localhost:5433/aadhi_studio"

# --- Storage ---
# local = files under .storage/ served via /api/assets (development default)
# s3    = any S3-compatible endpoint (AWS, MinIO, R2)
STORAGE_DRIVER="local"
LOCAL_STORAGE_DIR=".storage"
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Text generation providers (keys stay server-side; never shipped to the browser) ---
# Leave a key empty to disable that provider; the "mock" provider always works.
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Model names are configuration, not code. Admin settings (Settings page) can
# override these at runtime; these are the environment defaults.
OPENAI_TEXT_MODEL="gpt-4o-mini"
GEMINI_TEXT_MODEL="gemini-2.0-flash"
OPENAI_IMAGE_MODEL="gpt-image-1"

# --- Job queue ---
# inprocess = development queue inside the Next.js server process.
# The JobQueue interface is designed so a Redis/BullMQ driver can be added.
QUEUE_DRIVER="inprocess"
